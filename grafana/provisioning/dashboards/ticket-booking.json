{
  "title": "Ticket Booking Concurrency",
  "uid": "ticket-booking-concurrency",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Booking latency (p95 / p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(booking_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(booking_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 2,
      "title": "Lock wait time by strategy",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(booking_lock_wait_seconds_sum[1m]) / rate(booking_lock_wait_seconds_count[1m])",
          "legendFormat": "{{strategy}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Optimistic-lock retries",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(booking_optimistic_retry_attempts_total[1m])",
          "legendFormat": "retry attempts/s"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(booking_optimistic_retry_exhausted_total[1m])",
          "legendFormat": "retries exhausted/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Oversold (must stay 0)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "booking_oversold",
          "legendFormat": "oversoldBy"
        }
      ]
    }
  ]
}
